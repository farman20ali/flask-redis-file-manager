# Flask Configuration
# SECURITY WARNING: Change this to a strong random secret key in production!
FLASK_SECRET_KEY=your_secret_key_change_this_in_production
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Redis Configuration
# Replace with your Redis server details
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave empty if no password is required
REDIS_PASSWORD=

# Application Configuration
# Default user for file operations
DEFAULT_USER=your_username
# User role (admin or user)
DEFAULT_ROLE=admin
# Chunk size for file uploads (in bytes) - default is 1MB
CHUNK_SIZE=1048576

# Auth and sharing
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
GUEST_USERNAME=guest

# File expiry controls
FILE_DEFAULT_TTL_DAYS=30
FILE_MAX_TTL_DAYS=365
